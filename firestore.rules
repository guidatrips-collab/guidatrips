rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /experiences/{document} {
      allow read, write: if true;
    }
    match /posts/{document} {
      allow read, write: if true;
    }
    match /leads/{document} {
      allow read, write: if true;
    }
    match /settings/{document} {
      allow read, write: if true;
    }
  }
}
